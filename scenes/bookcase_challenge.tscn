size_flags_vertical = 3
bbcode_enabled = true
selection_enabled = true
text = "Бинарный (двоичный) поиск — это фундаментальный алгоритм поиска элемента в отсортированном массиве или списке. Его главная особенность и преимущество — скорость.

В отличие от обычного перебора (линейного поиска), где мы проверяем каждый элемент подряд, бинарный поиск действует по принципу «разделяй и властвуй»:

Смотрим в середину отсортированного массива.
Сравниваем: Средний элемент с искомым значением.
Если равен — нашли.
Если искомое больше среднего — значит, искать нужно только в правой половине (всё, что слева, точно меньше и нам не подходит).
Если искомое меньше среднего — искать нужно в левой половине.
Повторяем шаг 1 для выбранной половины, пока не найдем элемент или пока область поиска не сузится до нуля.

Пример кода:

sorted_numbers = [1, 3, 5, 7, 9, 11, 13]
target = 7
left = 0
right = len(sorted_numbers) - 1

while left <= right:
	mid = (left + right) // 2  # Находим середину
	if sorted_numbers[mid] == target:
		print(mid)             # Нашли элемент
		elif sorted_numbers[mid] < target:
			left = mid + 1        # Ищем в правой половине
		else:
			right = mid - 1       # Ищем в левой половине

    print(-1)  # Не нашли

# Использование:
print(binary_search(sorted_numbers, 7))  # Вывод: 3 (индекс числа 7)
"
fit_content = true

