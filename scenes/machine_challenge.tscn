[node name="RichTextLabel" type="RichTextLabel" parent="VBoxContainer/Content/TheoryPanel/TheoryContent" unique_id=1927544916]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
bbcode_enabled = true
text = "1. Частота элемента — сколько раз он встретился в списке.
2. Чтобы не сканировать весь список заново для каждого нового значения, заводят счётчики в словаре dict: ключ — элемент, значение — число вхождений.
3. Один проход по списку: для каждого элемента увеличиваем его счётчик в словаре.

В Python dict — это ассоциативный массив (на практике — хэш-таблица): обращение по ключу в среднем за O(1), весь подсчёт по n элементам — O(n).

Пример кода:
# список значений подряд
items = [\"a\", \"b\", \"a\", \"a\", \"b\"]

# вариант с проверкой: есть ли уже ключ
counts = {}
for x in items:
    if x in counts:
        counts[x] = counts[x] + 1
    else:
        counts[x] = 1

print(\"Частоты:\", counts)

# тот же смысл короче — get даёт 0, если ключа ещё не было
counts2 = {}
for x in items:
    counts2[x] = counts2.get(x, 0) + 1

print(\"Снова:\", counts2)
"
fit_content = true

