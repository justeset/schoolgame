layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
bbcode_enabled = true
text = "1. Мы сравниваем соседние элементы массива.
2. Если они стоят не в порядке (для убывания — больше слева, меньше справа), мы меняем их местами.
3. Проходим по всему массиву несколько раз, пока всё не станет отсортировано.

По убыванию: самые большие числа «всплывают» в начало массива.

Пример кода:
# Массив чисел
numbers = [5, 2, 9, 1, 7]

# Длина массива
n = len(numbers)

# Проходим по всему массиву
for i in range(n):
    # Сравниваем соседние элементы
    for j in range(0, n - i - 1):
        # Если левый элемент меньше правого (для убывания)
        if numbers[j] < numbers[j + 1]:
            # Меняем их местами
            numbers[j], numbers[j + 1] = numbers[j + 1], numbers[j]
    print(\"После прохода\", i + 1, \"массив выглядит так:\", numbers)

# Итоговый отсортированный массив
print(\"Отсортированный массив по убыванию:\", numbers)"
fit_content = true

