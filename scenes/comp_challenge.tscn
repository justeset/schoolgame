[node name="RichTextLabel" type="RichTextLabel" parent="VBoxContainer/Content/TheoryPanel/TheoryContent" unique_id=1927544916]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
bbcode_enabled = true
text = "Множества в Python (set) — это встроенный тип данных, представляющий собой неупорядоченную коллекцию уникальных элементов.

Представь коробку, в которую нельзя положить два одинаковых предмета, и при этом ты никогда не знаешь, в каком порядке они там лежат.

Основные характеристики: 
1. Уникальность — нет повторяющихся элементов
2. Неупорядоченность — Нельзя обратиться к элементу по индексу
3. Изменяемость — В set можно добавлять и удалять элементы (но сами элементы внутри должны быть неизменяемыми)
4. Скорость — Проверка наличия элемента работает очень быстро (в среднем за O(1))

Пример кода:
my_array = [1, 2, 3, 2, 1, 4, 5, 3, 6, 4]
    seen = set()
    result = []
    for item in my_array:
        if item not in seen:
            seen.add(item)
            result.append(item)
    return result

# Пример использования
print(\"Исходный массив:\", my_array)
print(\"Без повторений:\", remove_duplicates_preserve_order(my_array))"
fit_content = true

